# Copy to .env and fill in credentials that have Bedrock InvokeModel access
# for the target model. In production these come from an ECS task role,
# never from a static key/secret — see DESIGN.md.
AWS_REGION=ap-northeast-1
ANTHROPIC_MODEL=jp.anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# true enables the reference egress-firewall script inside each container.
ENABLE_FIREWALL=false
